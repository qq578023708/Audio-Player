{
  "name": "audioflow-player",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AudioFlow - Cross-platform network audio player (Vue3 + Electron + Capacitor)",
  "author": "AudioFlow",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:linux": "vite build && electron-builder --linux",
    "cap:init": "cap init \"AudioFlow\" \"com.audioflow.player\" --web-dir dist",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "fflate": "^0.8.2",
    "howler": "^2.2.4",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.7.0",
    "vite": "^6.2.0",
    "vue-tsc": "^2.2.0",
    "wait-on": "^8.0.1"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.audioflow.player",
    "productName": "AudioFlow",
    "copyright": "Copyright 2026 AudioFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.music",
      "icon": "public/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Audio",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AudioFlow Player"
    }
  }
}
